# Cloud SQL connection template for minEA
# Instance connection name: minea-a1d4c:us-central1:minea-a1d4c-2-instance
# Public IP: 34.41.177.66

# ─── Firebase Admin ──────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=minea-a1d4c
FIREBASE_CREDENTIALS_PATH=./fb_svc_acct.json

# ─── Database (pick one) ─────────────────────────────────────────────────────
# A) Public IP — add your IP to Cloud SQL authorized networks first
# Instance name: minea-a1d4c-2-instance  |  Database name: usually "postgres"
DATABASE_URL=postgresql+asyncpg://hminhas:YOUR_PASSWORD@34.41.177.66:5432/postgres

# B) Cloud SQL Auth Proxy — run `npm run db:proxy` in another terminal, then use:
# DATABASE_URL=postgresql+asyncpg://hminhas:YOUR_PASSWORD@127.0.0.1:5432/postgres

# ─── App ─────────────────────────────────────────────────────────────────────
DEBUG=true
WEB_APP_URL=http://localhost:3001

# ─── Email (Resend) — for org/workspace invites only, not auth verification ──
# RESEND_API_KEY=re_...
# EMAIL_FROM=minEA <noreply@yourdomain.com>

CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","https://minea-a1d4c.web.app","https://minea-a1d4c.firebaseapp.com"]
