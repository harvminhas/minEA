# Cloud SQL connection template for minEA
# Instance connection name: minea-a1d4c:us-central1:minea-a1d4c-2-instance
# Public IP: 34.41.177.66

# ─── Firebase Admin ──────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=minea-a1d4c
FIREBASE_CREDENTIALS_PATH=./fb_svc_acct.json
# Vercel / production: paste the full JSON string (no file on disk)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ─── Database (pick one) ─────────────────────────────────────────────────────
# A) Public IP — add your IP to Cloud SQL authorized networks first
# Instance name: minea-a1d4c-2-instance  |  Database name: usually "postgres"
DATABASE_URL=postgresql+asyncpg://hminhas:YOUR_PASSWORD@34.41.177.66:5432/postgres
DATABASE_SSL=true
# Vercel + Cloud SQL: default CA bundle cannot verify Cloud SQL certs.
# Quick fix: DATABASE_SSL_VERIFY=false  (TLS encrypted, server not verified)
# Better: download server-ca.pem from Cloud SQL → Connections → paste as DATABASE_SSL_CA

# B) Cloud SQL Auth Proxy — run `npm run db:proxy` in another terminal, then use:
# DATABASE_URL=postgresql+asyncpg://hminhas:YOUR_PASSWORD@127.0.0.1:5432/postgres

# ─── Google Gemini (AI chat, insights, ingestion) ────────────────────────────
# Get a key at https://aistudio.google.com/apikey
# GOOGLE_API_KEY=...
# GEMINI_MODEL=gemini-2.5-flash
# Cheaper alternative: gemini-2.5-flash-lite
# Note: gemini-2.0-flash was retired 2026-06-01.

# ─── App ─────────────────────────────────────────────────────────────────────
DEBUG=true
WEB_APP_URL=http://localhost:3001

# Vercel: add your web app URL, e.g. https://minea-web.vercel.app
# CORS_ORIGINS=["http://localhost:3000","https://minea-web.vercel.app"]

# ─── Email (Resend) — for org/workspace invites only, not auth verification ──
# RESEND_API_KEY=re_...
# EMAIL_FROM=minEA <noreply@yourdomain.com>
