{
  "name": "@minea/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "python -m uvicorn app.main:app --reload --reload-include .env --host 127.0.0.1 --port 8000",
    "start": "python -m uvicorn app.main:app --host 0.0.0.0 --port 8000",
    "db:migrate": "python scripts/migrate.py",
    "db:set-plan": "python scripts/set_org_plan.py",
    "db:proxy": "powershell -ExecutionPolicy Bypass -File ../../scripts/cloud-sql-proxy.ps1"
  }
}
