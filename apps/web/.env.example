# ─── Firebase (client — safe to expose in browser) ───────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Browser calls /api/v1/* on this app; Next.js proxies to API_URL at request time.
# Production (Vercel web project): https://min-ea-api.vercel.app
API_URL=http://localhost:8000

# ─── Database (API only — put in apps/api/.env) ───────────────────────────────
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/minea

# ─── Firebase Admin (API only — put in apps/api/.env) ───────────────────────
# FIREBASE_PROJECT_ID=minea-a1d4c
# FIREBASE_CREDENTIALS_PATH=/path/to/serviceAccountKey.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
